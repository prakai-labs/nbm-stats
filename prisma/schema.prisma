// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// รายการห้องเรียนของโรงเรียนบ้านหนองบัวโนนเมือง
model Classroom {
  id        String   @id @default(cuid())
  code      String   @unique // เช่น "ป.1", "อ.1", "ม.1"
  name      String            // ชื่อเต็ม เช่น "ประถมศึกษาปีที่ 1"
  level     String            // ระดับ เช่น "อนุบาล", "ประถม", "มัธยมต้น"
  sortOrder Int      @default(0)
  records   AttendanceRecord[]
}

// บันทึกสถิตินักเรียนรายวัน แยกตามห้องเรียน พร้อมแยกชาย-หญิงทุกสถานะ
model AttendanceRecord {
  id            String   @id @default(cuid())
  date          String             // YYYY-MM-DD (รองรับ timezone ไทย)
  classroomId   String
  classroom     Classroom @relation(fields: [classroomId], references: [id])
  // จำนวนนักเรียนทั้งหมด
  totalMale     Int      @default(0) // จำนวนนักเรียนชายทั้งหมดของห้อง
  totalFemale   Int      @default(0) // จำนวนนักเรียนหญิงทั้งหมดของห้อง
  // ป่วย (แยกชาย/หญิง)
  sickMale      Int      @default(0)
  sickFemale    Int      @default(0)
  // ลา (แยกชาย/หญิง)
  leaveMale     Int      @default(0)
  leaveFemale   Int      @default(0)
  // ขาด (แยกชาย/หญิง)
  absentMale    Int      @default(0)
  absentFemale  Int      @default(0)
  // มา (คำนวณอัตโนมัติ = ชาย/หญิง ทั้งหมด - ป่วย - ลา - ขาด)
  presentMale   Int      @default(0)
  presentFemale Int      @default(0)
  note          String?             // หมายเหตุ เช่น กิจกรรมพิเศษ
  recordedBy    String?             // ชื่อผู้บันทึก (คุณครู)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([date, classroomId])
  @@index([date])
}
