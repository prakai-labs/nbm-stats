# ============================================================
# ตัวอย่าง Environment Variables สำหรับ Vercel
# ============================================================
# คัดลอกไฟล์นี้เป็น .env ในเครื่องทดสอบ หรือใส่ค่าใน Vercel dashboard
# (Project Settings → Environment Variables)
#
# สำคัญ: อย่า commit ค่าจริงลง GitHub! ใช้ Vercel dashboard เท่านั้น
# ============================================================

# Database — ใช้ Vercel Postgres หรือ Supabase หรือ Neon
# ตัวอย่าง Vercel Postgres: postgresql://default:xxx@ep-xxx-pooler.region.aws.neon.tech/verceldb?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# สำหรับ Vercel Postgres ที่ใช้ pooler (แนะนำ) — ตั้งค่า directUrl แยก
# ถ้าใช้ Neon/Supabase ที่ไม่มี pooler ตั้งค่าเดียวกับ DATABASE_URL ได้
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# NextAuth
# สร้างด้วย: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_TO_RANDOM_32_CHAR_STRING
NEXTAUTH_URL=https://nbm-stats.vercel.app

# Google OAuth
# จาก Google Cloud Console → Credentials → OAuth client ID
GOOGLE_CLIENT_ID=88781518013-5nibilv9ga6hbsp2ap20sq6trbh4hr3g.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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

# Optional: จำกัดเฉพาะครูของโรงเรียน (คั่นด้วยจุลภาค)
# ALLOWED_EMAILS=kru1@bnnm.ac.th,kru2@bnnm.ac.th
